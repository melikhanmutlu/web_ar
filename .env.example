# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=production
DEBUG=False

# Database (Railway will provide DATABASE_URL automatically)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Upload Configuration
MAX_CONTENT_LENGTH=104857600
UPLOAD_FOLDER=uploads
CONVERTED_FOLDER=converted
TEMP_FOLDER=temp

# Conversion Settings
DEFAULT_MAX_DIMENSION=0.5
DEFAULT_COLOR=#4CAF50

# External Tools
FBX2GLTF_PATH=tools/FBX2glTF.exe
OBJ2GLTF_COMMAND=npx obj2gltf

# AI 3D generation (Meshy) — server-side only
MESHY_API_KEY=
MESHY_API_BASE=https://api.meshy.ai/openapi
MESHY_AI_MODEL=meshy-5
# Image generation model for the optional pre-processing step
MESHY_IMAGE_MODEL=nano-banana-pro
AI_GEN_DAILY_LIMIT=10

# Optional: enable fail-safe GLB compression (gltfpack). Off by default.
GLB_OPTIMIZE=false
