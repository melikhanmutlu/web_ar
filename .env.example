# Flask
SECRET_KEY=change-me-in-production
DEBUG=False

# Database — Railway injects DATABASE_URL automatically; local dev uses SQLite.
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Conversion queue: true = worker.py processes uploads (production),
# false = uploads convert inline in the web request (local dev default).
JOB_QUEUE=false

# iOS Quick Look USDZ export via Blender (skipped automatically if Blender
# is not installed).
USDZ_EXPORT=true

# Public base URL used for QR codes generated by the worker process.
# Railway sets RAILWAY_PUBLIC_DOMAIN automatically; set this only to override.
# PUBLIC_BASE_URL=https://example.com

# Upload limit in bytes (default 100 MB).
# WEB_AR_MAX_CONTENT_LENGTH=104857600

# Storage directories — point at a Railway volume to persist files.
# WEB_AR_UPLOAD_DIR=/data/uploads
# WEB_AR_CONVERTED_DIR=/data/converted
# WEB_AR_QR_DIR=/data/qr_codes
